{
  "manifest_version": 3,
  "name": "Ultimate PiP",
  "version": "0.0.0-replaced-at-build-time",
  "description": "Picture-in-picture controls for HTML5 video.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true
    }
  ],
  "commands": {
    "toggle-picture-in-picture": {
      "suggested_key": {
        "default": "Alt+Shift+P"
      },
      "description": "Toggle picture-in-picture for the active video"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "Toggle picture-in-picture",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "ultimate-pip@gormanity",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
